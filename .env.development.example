# 复制为 .env.development 后按需修改（勿提交含密钥的文件）

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# CORS（多个源用逗号分隔）
CORS_ORIGIN=http://localhost:5173,http://localhost:4000
CORS_CREDENTIALS=true

# JWT Cookie 有效期（秒）
JWT_EXPIRES_IN_SECONDS=2592000

# 数据库驱动（可选）：sqlite | postgresql
# 未设置时：开发环境默认 sqlite，生产环境默认 postgresql
# DB_PROVIDER=sqlite

# SQLite（开发默认）
SQLITE_DB_URL=./.data/db.sqlite3

# PostgreSQL（生产 / 开发可切换）
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=mmfblog_v2

# 应用
MD5_SALT=!@#$%(*&^)
LOG_LEVEL=info
SWAGGER_PATH=/docs
